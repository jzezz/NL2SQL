# Choose ONE provider:

# Option 1: Groq (free, fast, recommended)
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_your_key_here
# LLM_MODEL=llama3-8b-8192

# Option 2: OpenAI (pay per use)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk_your_key_here
# LLM_MODEL=gpt-4o-mini

# Option 3: Google Gemini (free tier with quota limits)
# LLM_PROVIDER=google
# GOOGLE_API_KEY=your_key_here

# Optional: Custom base URL (for proxies)
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Database (auto-configured for Vercel)
# DATABASE_PATH=data/clinic.db